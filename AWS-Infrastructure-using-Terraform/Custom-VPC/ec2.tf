terraform {
  required_providers {
    aws = {
      source = "hashicorp/aws"
    }
    tls = {
      source = "hashicorp/tls"
    }
    local = {
      source = "hashicorp/local"
    }
  }
}

# -------------------------------------------------------------
# KEY PAIR
# Terraform generates an RSA key pair, uploads the public key to AWS,
# and stores the private key locally for SSH usage.
# -------------------------------------------------------------
resource "tls_private_key" "ec2_ssh_key" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

resource "aws_key_pair" "generated_key" {
  key_name   = var.key_name
  public_key = tls_private_key.ec2_ssh_key.public_key_openssh
}

resource "local_file" "private_key_pem" {
  filename        = "${path.module}/${var.key_name}.pem"
  file_permission = "0400"
  content         = tls_private_key.ec2_ssh_key.private_key_pem
}

# -------------------------------------------------------------
# PUBLIC WEB SERVER INSTANCE
# Uses user_data to install Nginx and show instance metadata on index page.
# -------------------------------------------------------------
resource "aws_instance" "web_server" {
  ami                    = var.ami_id
  instance_type          = var.instance_type
  subnet_id              = aws_subnet.public_subnet_1.id
  vpc_security_group_ids = [aws_security_group.web_server_sg.id]
  key_name               = aws_key_pair.generated_key.key_name
  # Attach the custom IAM instance profile so this EC2 can access only the assignment bucket.
  iam_instance_profile = aws_iam_instance_profile.ec2_s3_profile.name

  user_data = <<-EOF
              #!/bin/bash
              set -euxo pipefail

              dnf update -y || yum update -y
              dnf install -y nginx curl || yum install -y nginx curl

              systemctl enable nginx
              systemctl start nginx

              TOKEN=$(curl -X PUT "http://169.254.169.254/latest/api/token" \
                -H "X-aws-ec2-metadata-token-ttl-seconds: 21600")
              INSTANCE_ID=$(curl -H "X-aws-ec2-metadata-token: $TOKEN" \
                http://169.254.169.254/latest/meta-data/instance-id)

              cat > /usr/share/nginx/html/index.html <<HTML
              <html>
              <body>
                <h1>Web Server is Running</h1>
                <p>Instance ID: $INSTANCE_ID</p>
              </body>
              </html>
              HTML

              systemctl restart nginx
              EOF

  tags = {
    Name = "Web-Server-Public"
  }
}

# -------------------------------------------------------------
# PRIVATE DATABASE SERVER INSTANCE
# Stays in private subnet with private SG.
# -------------------------------------------------------------
resource "aws_instance" "db_server" {
  ami                    = var.ami_id
  instance_type          = var.instance_type
  subnet_id              = aws_subnet.private_subnet_1.id
  vpc_security_group_ids = [aws_security_group.db_server_sg.id]
  key_name               = aws_key_pair.generated_key.key_name

  tags = {
    Name = "DB-Server-Private"
  }
}

output "generated_private_key_path" {
  description = "Path to SSH private key generated by Terraform"
  value       = local_file.private_key_pem.filename
}
