# ============================================================
# ROOT — Global .gitignore for the entire repo
# Covers ALL subfolders: SkillSwap/ + AWS-Infrastructure/
# ============================================================

# ============================================================
# macOS — System junk (NEVER push)
# ============================================================
.DS_Store
.AppleDouble
.LSOverride
**/.DS_Store

# ============================================================
# NODE.JS — Dependencies
# ============================================================
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================
# ENVIRONMENT VARIABLES — SECRET (NEVER push)
# ============================================================
.env
**/.env
.env.local
.env.*.local

# ============================================================
# TERRAFORM — State & Secrets (NEVER push)
# ============================================================
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
*.pem
*.key
crash.log
*.tfplan

# ============================================================
# REACT — Build output
# ============================================================
client/build/

# ============================================================
# LOGS
# ============================================================
*.log
logs/

# ============================================================
# WINDOWS
# ============================================================
Thumbs.db
Desktop.ini
